# Shared PostgreSQL
DB_PASSWORD=beast_dev_password

# BEAST API
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000

# Orchestrator queue (Valkey)
VALKEY_URL=redis://valkey:6379

# Claude Code Scanner (claude-runner)
# SSH public key for API -> claude-runner/security-tools (auto-set by `make setup-keys`)
SCANNER_SSH_PUBKEY=
# Note: Claude Code authenticates via OAuth, not API key
# After first start, run: docker exec -it beast-claude-runner-1 su - scanner -c "claude login"

# JFrog Xray (jf audit — SCA dependency scanning)
JF_URL=https://beastapp.jfrog.io
JF_ACCESS_TOKEN=
